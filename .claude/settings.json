{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "agentTeamDisplay": "tmux",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash .bkit/hooks/destructive-detector.sh", "timeout": 5000 },
          { "type": "command", "command": "bash .bkit/hooks/pane-access-guard.sh", "timeout": 5000 },
          { "type": "command", "command": "bash .bkit/hooks/enforce-spawn.sh", "timeout": 5000 },
          { "type": "command", "command": "bash .bkit/hooks/prevent-tmux-kill.sh", "timeout": 5000 },
          { "type": "command", "command": "bash .bkit/hooks/validate-coo-approval.sh", "timeout": 5000 },
          { "type": "command", "command": "bash .bkit/hooks/validate-task-fields.sh", "timeout": 5000 },
          { "type": "command", "command": "bash .bkit/hooks/validate-slack-payload.sh", "timeout": 5000 },
          { "type": "command", "command": "bash .bkit/hooks/validate-qa.sh", "timeout": 10000 },
          { "type": "command", "command": "bash .bkit/hooks/validate-pdca.sh", "timeout": 15000 },
          { "type": "command", "command": "bash .bkit/hooks/validate-task.sh", "timeout": 15000 },
          { "type": "command", "command": "bash .bkit/hooks/enforce-qa-before-merge.sh", "timeout": 120000 },
          { "type": "command", "command": "bash .bkit/hooks/validate-deploy-authority.sh", "timeout": 5000 },
          { "type": "command", "command": "bash .bkit/hooks/postmortem-review-gate.sh", "timeout": 10000 }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash .bkit/hooks/validate-delegate.sh", "timeout": 5000 },
          { "type": "command", "command": "bash .bkit/hooks/validate-plan.sh", "timeout": 10000 },
          { "type": "command", "command": "bash .bkit/hooks/validate-design.sh", "timeout": 15000 }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          { "type": "command", "command": "bash .bkit/hooks/enforce-teamcreate.sh", "timeout": 5000 }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          { "type": "command", "command": "bash .bkit/hooks/validate-before-delegate.sh", "timeout": 10000 }
        ]
      },
      {
        "matcher": "TeamDelete",
        "hooks": [
          { "type": "command", "command": "bash .bkit/hooks/validate-pdca-before-teamdelete.sh", "timeout": 10000 }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          { "type": "command", "command": "bash .bkit/hooks/task-completed.sh", "timeout": 10000 },
          { "type": "command", "command": "bash .bkit/hooks/task-quality-gate.sh", "timeout": 120000 },
          { "type": "command", "command": "bash .bkit/hooks/gap-analysis.sh", "timeout": 15000 },
          { "type": "command", "command": "bash .bkit/hooks/pdca-update.sh", "timeout": 30000 },
          { "type": "command", "command": "bash .bkit/hooks/filter-completion-dm.sh", "timeout": 5000 },
          { "type": "command", "command": "bash .bkit/hooks/notify-completion.sh", "timeout": 10000 },
          { "type": "command", "command": "bash .bkit/hooks/deploy-trigger.sh", "timeout": 10000 },
          { "type": "command", "command": "bash .bkit/hooks/deploy-verify.sh", "timeout": 5000 },
          { "type": "command", "command": "bash .bkit/hooks/pdca-chain-handoff.sh", "timeout": 15000 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "TeamCreate",
        "hooks": [
          { "type": "command", "command": "bash .bkit/hooks/registry-update.sh", "timeout": 5000 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash .bkit/hooks/auto-shutdown.sh", "timeout": 10000 },
          { "type": "command", "command": "bash .bkit/hooks/auto-team-cleanup.sh", "timeout": 10000 }
        ]
      }
    ]
  },
  "permissionMode": "bypassPermissions"
}
