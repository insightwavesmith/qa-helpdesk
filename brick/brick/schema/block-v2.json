{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "brick/block-v2",
  "title": "Brick Block V2",
  "type": "object",
  "required": ["id", "what", "done"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
    "what": {"type": "string", "minLength": 1},
    "done": {
      "type": "object",
      "properties": {
        "artifacts": {"type": "array", "items": {"type": "string"}},
        "metrics": {"type": "object"},
        "custom": {"type": "array", "items": {"type": "string"}}
      }
    },
    "type": {
      "type": "string",
      "enum": ["Plan", "Design", "Do", "Check", "Act", "Research", "Review", "Report", "Cron", "Custom"]
    },
    "description": {"type": "string"},
    "gate": {"$ref": "#/definitions/gate_config"},
    "input": {
      "type": "object",
      "properties": {
        "from_block": {"type": "string"},
        "artifacts": {"type": "array", "items": {"type": "string"}}
      }
    },
    "timeout": {"type": "integer", "minimum": 0},
    "idempotent": {"type": "boolean"},
    "metadata": {"type": "object"},
    "fallback_adapter": {"type": "string"}
  },
  "definitions": {
    "gate_config": {
      "type": "object",
      "properties": {
        "handlers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {"type": "string", "enum": ["command", "http", "prompt", "agent", "metric", "approval"]},
              "metric": {"type": "string"},
              "threshold": {"type": "number"},
              "approval": {"type": "object"},
              "command": {"type": "string"},
              "url": {"type": "string"},
              "prompt": {"type": "string"},
              "model": {"type": "string"},
              "timeout": {"type": "integer"},
              "on_fail": {"type": "string", "enum": ["fail", "warn", "skip"]},
              "confidence_threshold": {"type": "number"},
              "retries": {"type": "integer"}
            }
          }
        },
        "evaluation": {"type": "string", "enum": ["sequential", "parallel", "vote"]},
        "on_fail": {"type": "string", "enum": ["retry", "rollback", "escalate", "skip"]},
        "max_retries": {"type": "integer"}
      }
    }
  }
}
