{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "brick/team-v2",
  "title": "Brick Team V2",
  "type": "object",
  "required": ["adapter"],
  "properties": {
    "adapter": {
      "type": "string",
      "enum": ["claude_agent_teams", "claude_code", "human", "webhook", "codex"]
    },
    "config": {
      "type": "object",
      "properties": {
        "session": {"type": "string"},
        "role": {"type": "string"},
        "broker_port": {"type": "integer"},
        "url": {"type": "string"},
        "headers": {"type": "object"},
        "completions_dir": {"type": "string"}
      }
    }
  }
}
