{
  "name": "bscamp-extension",
  "version": "1.0.0",
  "description": "자사몰사관학교 블로그 도우미 크롬 확장",
  "private": true,
  "scripts": {
    "dev": "npm run build",
    "build": "npm run build:popup && npm run build:content && npm run build:worker && npm run copy-assets",
    "build:popup": "VITE_BUILD_TARGET=popup vite build",
    "build:content": "VITE_BUILD_TARGET=content vite build",
    "build:worker": "VITE_BUILD_TARGET=worker vite build",
    "copy-assets": "cp manifest.json dist/ && mkdir -p dist/assets/icons && cp src/assets/icons/*.png dist/assets/icons/",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
